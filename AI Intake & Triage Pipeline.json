    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  const d = item.json;\n\n  const category = d.category || \"\";\n  const confidence = Number(d.confidence_score ?? 0);\n  const msg = String(d.raw_message || \"\").toLowerCase();\n\n  let identifiers = {};\n  try {\n    identifiers = JSON.parse(d.identifiers || \"{}\");\n  } catch {\n    identifiers = {};\n  }\n\n  const routingMap = {\n    \"Bug Report\": \"Engineering\",\n    \"Incident/Outage\": \"Incident Response\",\n    \"Feature Request\": \"Product\",\n    \"Billing Issue\": \"Billing\",\n    \"Technical Question\": \"IT/Security\",\n  };\n\n  const original_queue = routingMap[category] || \"General Support\";\n\n  let destination_queue = original_queue;\n  let escalation_flag = false;\n  const escalation_reasons = [];\n\n  if (confidence < 0.70) {\n    escalation_flag = true;\n    escalation_reasons.push(`Low confidence: ${(confidence * 100).toFixed(0)}%`);\n  }\n\n  const criticalKeywords = [\n    \"outage\",\n    \"down for all users\",\n    \"multiple users affected\",\n    \"production down\",\n    \"data loss\",\n    \"security breach\",\n    \"unauthorized access\",\n    \"service unavailable\",\n    \"down\"\n  ];\n\n  for (const keyword of criticalKeywords) {\n    if (msg.includes(keyword)) {\n      escalation_flag = true;\n      escalation_reasons.push(`Critical keyword: \"${keyword}\"`);\n      break;\n    }\n  }\n\n  const amounts = Array.isArray(identifiers.amounts_mentioned)\n    ? identifiers.amounts_mentioned\n        .map(a => Number(String(a).replace(/[^0-9.]/g, \"\")))\n        .filter(n => !Number.isNaN(n))\n    : [];\n\n  if (category === \"Billing Issue\" && amounts.length >= 2) {\n    const sorted = [...amounts].sort((a, b) => b - a);\n    const discrepancy = Math.abs(sorted[0] - sorted[1]);\n\n    if (discrepancy > 500) {\n      escalation_flag = true;\n      escalation_reasons.push(`Billing discrepancy over $500: $${discrepancy.toFixed(2)}`);\n    }\n  }\n\n  if (escalation_flag) {\n    destination_queue = \"Escalation - Human Review\";\n  }\n\n  return {\n    json: {\n      ...d,\n      original_queue,\n      destination_queue,\n      escalation_flag,\n      escalation_reasons: escalation_reasons.join(\"; \")\n    }\n  };\n});"
      },
