    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item, index) => {\n  const current = item.json;\n\n  const rawText = current.output?.[0]?.content?.[0]?.text;\n\n  if (!rawText) {\n    throw new Error(\"No AI text output found.\");\n  }\n\n  let ai;\n  try {\n    ai = JSON.parse(rawText);\n  } catch (error) {\n    throw new Error(\"Failed to parse AI JSON: \" + rawText);\n  }\n\n  const original = $(\"Merge\").all()[index]?.json || $(\"Merge\").all()[0]?.json || {};\n\n  const cleanRawMessage = String(original.raw_message || \"\")\n    .replace(/&#39;/g, \"'\")\n    .replace(/&quot;/g, '\"')\n    .replace(/&amp;/g, \"&\");\n\n  const identifiers = ai.identifiers || {};\n\n  return {\n    json: {\n      request_id: `REQ-${$execution.id}-${index}`,\n      source: original.source === \"gmail\" ? \"Email\" : original.source || \"\",\n      sender: original.sender || \"\",\n      raw_message: cleanRawMessage,\n      received_at: original.received_at || \"\",\n\n      category: ai.category || \"\",\n      priority: ai.priority || \"\",\n      confidence_score: Number(ai.confidence_score ?? 0),\n      classification_reasoning: ai.classification_reasoning || \"\",\n      core_issue: ai.core_issue || \"\",\n\n      identifiers: JSON.stringify(identifiers),\n\n      urgency_signal: ai.urgency_signal || \"\",\n      summary: ai.summary || \"\",\n      suggested_sla: ai.suggested_sla || \"\"\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1264,
